{
  "name": "wc2026-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "2026 世界杯 + AI 预测 静态网页",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "update:result": "node scripts/update-result.js",
    "update:prediction": "node scripts/add-prediction.js",
    "modeling:fit": "node modeling/scripts/33_fit_strategy.js",
    "modeling:fit:backtest": "node modeling/scripts/31_tight_anti_value.js --backtest",
    "modeling:predict": "node modeling/scripts/31_tight_anti_value.js --predict",
    "modeling:all": "node modeling/scripts/33_fit_strategy.js && node modeling/scripts/31_tight_anti_value.js --predict",
    "embeddings:build": "node scripts/build_embeddings.js",
    "chat:dev": "vercel dev",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "vite": "^6.0.0",
    "wrangler": "^4.107.0"
  },
  "dependencies": {
    "chart.js": "^4.4.6"
  }
}
