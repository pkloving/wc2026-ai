{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": false,
  "functions": {
    "api/**/*.js": {
      "includeFiles": "{data,modeling/artifacts}/**"
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/data/odds/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/data/results/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=7200, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/data/embeddings/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/(js|css)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/matches", "destination": "/matches.html" },
    { "source": "/predictions", "destination": "/predictions.html" },
    { "source": "/stats", "destination": "/stats.html" },
    { "source": "/teams", "destination": "/teams.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/bets", "destination": "/bets.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/simulate", "destination": "/simulate.html" },
    { "source": "/lab", "destination": "/lab.html" },
    { "source": "/frequency", "destination": "/frequency.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/match", "destination": "/match.html" }
  ],
  "redirects": [
    { "source": "/schedule", "destination": "/matches.html#schedule", "permanent": true },
    { "source": "/schedule.html", "destination": "/matches.html#schedule", "permanent": true },
    { "source": "/standings", "destination": "/matches.html#standings", "permanent": true },
    { "source": "/standings.html", "destination": "/matches.html#standings", "permanent": true },
    { "source": "/results", "destination": "/matches.html#results", "permanent": true },
    { "source": "/results.html", "destination": "/matches.html#results", "permanent": true },
    { "source": "/backtest", "destination": "/lab.html", "permanent": true },
    { "source": "/backtest.html", "destination": "/lab.html", "permanent": true }
  ]
}
