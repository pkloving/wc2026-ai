# DeepSeek LLM（主对话模型）
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# 可选：覆盖默认模型（默认 deepseek-chat，即 V3.2）
# 也可填 deepseek-reasoner（R1）
DEEPSEEK_MODEL=deepseek-chat

# 硅基流动 embedding（bge-m3，中文强，便宜）
# https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=

# 博查 AI Search（联网搜索，触发于伤停/首发/突发新闻等）
# https://open.bochaai.com/
BOCHA_API_KEY=

# ----- v0.2 新增 -----

# Resend 邮件发送（OTP 验证码）
# https://resend.com/api-keys
# 留空时自动降级为「控制台打印验证码」（开发模式）
RESEND_API_KEY=
# 发件人地址，域名必须是「上面这把 key 所属账号」里已 verified 的域名
# 留空则用默认 noreply@wc2026-ai.top
EMAIL_FROM="WC2026 AI 助手 <noreply@wc2026-ai.top>"

# Upstash Redis（鉴权 / 积分 / 限流 / session 存储）
# https://console.upstash.com/ → 选 Global / Regional 都行，free tier 256MB 够用
# Vercel 部署时推荐直接用 Vercel Marketplace 里的 Upstash 集成，自动注入这两个 env
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin 后台密码（访问 /admin.html 时需要）
# 任意强密码串，不要 commit 到 git
ADMIN_KEY=
